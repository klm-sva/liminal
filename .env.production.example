# ============================================================
# Liminal — Railway Production Environment Variables
# Copy every variable below into Railway → Project → Variables
# Never commit actual values to source control.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# From: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...          # "anon public" key
SUPABASE_SERVICE_ROLE_KEY=eyJ...              # "service_role" key — keep secret

# ── Anthropic ────────────────────────────────────────────────
# From: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Maps ──────────────────────────────────────────────
# From: console.cloud.google.com → APIs & Services → Credentials
# Required for pipeline LT/SS credit location analysis
GOOGLE_MAPS_API_KEY=AIza...

# ── Stripe ───────────────────────────────────────────────────
# From: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...                 # Use sk_live_ in production
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_... # Use pk_live_ in production

# From: Stripe dashboard → Developers → Webhooks → your endpoint → Signing secret
# Endpoint to register: https://your-railway-domain.up.railway.app/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — from Stripe dashboard → Products
# Create one product per tier with a monthly recurring price
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_PROFESSIONAL_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...     # Optional — leave blank if not used

# ── Resend (email) ───────────────────────────────────────────
# From: resend.com → API Keys
RESEND_API_KEY=re_...
# Must match a verified sending domain in Resend
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── UploadThing ──────────────────────────────────────────────
# From: uploadthing.com → your app → API Keys
UPLOADTHING_SECRET=sk_live_...
UPLOADTHING_APP_ID=your-app-id

# ── Internal secrets ─────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Used to authenticate internal webhook calls between the app and pipeline
WEBHOOK_SECRET=generate-a-random-64-char-hex-string

# Used to authenticate calls to POST /api/admin/cleanup
CLEANUP_SECRET=generate-a-different-random-64-char-hex-string

# ── App URL ──────────────────────────────────────────────────
# Set to your Railway public domain once deployed
# Example: https://liminalsva-production.up.railway.app
# Or your custom domain if configured in Railway
NEXT_PUBLIC_APP_URL=https://your-railway-domain.up.railway.app

# ── Railway-injected (do NOT set manually) ───────────────────
# Railway automatically provides these — no action needed:
# PORT          — the port Next.js should listen on (Railway sets this)
# RAILWAY_ENVIRONMENT — "production" when deployed
